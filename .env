# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JDownloader Account (required)
JD_EMAIL=your_jdownloader_email@example.com
JD_PASSWORD=your_jdownloader_password
JD_DEVICE_NAME=TelegramBot

# User Authorization (optional - comma-separated Telegram user IDs)
ALLOWED_USERS=123456789,987654321

# Download Settings
DOWNLOAD_PATH=/app/downloads
MAX_FILE_SIZE=2000  # In MB

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log

# Health Check
HEALTH_CHECK_PORT=8080

# Connection Settings
JD_CONNECTION_TIMEOUT=30
JD_RECONNECT_INTERVAL=300

# Upload Settings
UPLOAD_CHUNK_SIZE=5242880  # 5MB
UPLOAD_RETRY_COUNT=3
